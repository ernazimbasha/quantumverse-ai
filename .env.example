# Database Configuration (PostgreSQL via Railway)
DATABASE_URL="postgresql://postgres:password@localhost:5432/quantumverse"

# Authentication (NextAuth)
# Generate a real secret using: openssl rand -base64 32
NEXTAUTH_SECRET="your_nextauth_secret_here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth Provider
GOOGLE_CLIENT_ID="your_google_client_id_here"
GOOGLE_CLIENT_SECRET="your_google_client_secret_here"

# AI Integration (Anthropic Claude 3.5 Sonnet / 4.6 Sonnet)
ANTHROPIC_API_KEY="your_anthropic_api_key_here"

# Code Execution Microservice (FastAPI)
NEXT_PUBLIC_API_URL="http://localhost:8000"
JWT_SECRET="microservice_secure_jwt_secret_key_here"
